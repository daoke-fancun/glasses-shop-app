/* 验光数据页面样式 */
.container {
  padding: 16rpx;
}

.card {
  background-color: white;
  border-radius: 8rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  margin-bottom: 8rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.form-input {
  width: 100%;
  padding: 16rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
  font-size: 28rpx;
  background-color: #f9f9f9;
}

.section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  color: #333;
  padding-bottom: 8rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.row {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.col {
  flex: 1;
}

.btn {
  display: block;
  width: 100%;
  padding: 20rpx;
  background-color: #1a73e8;
  color: white;
  text-align: center;
  border-radius: 8rpx;
  margin-top: 32rpx;
  font-size: 30rpx;
  font-weight: 500;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .row {
    flex-direction: column;
    gap: 16rpx;
  }
  
  .col {
    width: 100%;
  }
}