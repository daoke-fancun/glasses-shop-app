<view class="tabs">
  <view bindtap="switchTab" data-type="all" class="{{currentTab === 'all' ? 'active' : ''}}">全部</view>
  <view bindtap="switchTab" data-type="frame" class="{{currentTab === 'frame' ? 'active' : ''}}">镜框</view>
  <view bindtap="switchTab" data-type="lens" class="{{currentTab === 'lens' ? 'active' : ''}}">镜片</view>
</view>

<block wx:for="{{products}}" wx:key="name">
  <view wx:if="{{currentTab === 'all' || item.category === currentTab}}" class="product-item">
    {{item.name}} - ¥{{item.price}}
  </view>
</block>