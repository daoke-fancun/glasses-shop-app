<view class="container">
  <view class="appointment-form">
    <h1>预约到店</h1>
    
    <view class="form-item">
      <view class="form-label">姓名</view>
      <input class="form-input" placeholder="请输入姓名" bindinput="bindNameInput" />
    </view>
    
    <view class="form-item">
      <view class="form-label">手机号码</view>
      <input class="form-input" placeholder="请输入手机号码" bindinput="bindPhoneInput" />
    </view>
    
    <view class="form-item">
      <view class="form-label">预约日期</view>
      <input class="form-input" placeholder="请选择日期" bindtap="bindDatePicker" value="{{date}}" />
    </view>
    
    <view class="form-item">
      <view class="form-label">预约时间</view>
      <input class="form-input" placeholder="请选择时间" bindtap="bindTimePicker" value="{{time}}" />
    </view>
    
    <view class="form-item">
      <view class="form-label">预约服务</view>
      <picker class="form-input" range="{{services}}" bindchange="bindServiceChange" value="{{serviceIndex}}">
        <view class="form-input">{{services[serviceIndex]}}</view>
      </picker>
    </view>
    
    <view class="form-item">
      <view class="form-label">备注</view>
      <textarea class="form-input" placeholder="请输入备注信息" bindinput="bindRemarkInput" style="height: 150rpx;" />
    </view>
    
    <view class="btn" bindtap="submitAppointment">提交预约</view>
  </view>
</view>