/* 我的页面样式 */
.container {
  padding: 16rpx;
  background-color: #f5f9ff;
  min-height: 100vh;
}

/* 用户信息 */
.user-info {
  background-color: white;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  text-align: center;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  margin: 0 auto 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #1a73e8;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
  color: #333;
}

.user-phone {
  font-size: 24rpx;
  color: #666;
}

/* 视力管家卡片 */
.health-card {
  background-color: white;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.health-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #1a73e8;
  color: white;
}

.health-card-title {
  font-size: 32rpx;
  font-weight: bold;
}

.health-status {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.health-status.healthy {
  background-color: #4caf50;
}

.health-status.warning {
  background-color: #f44336;
}

.health-card-body {
  padding: 20rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.last-check,
.check-interval {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.last-check-label,
.check-interval-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.last-check-date,
.check-interval-days {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

/* 验光数据展示区 */
.optometry-data {
  background-color: white;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.data-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 1rpx;
  background-color: #e0e0e0;
  border-radius: 8rpx;
  overflow: hidden;
  margin: 20rpx 0;
}

.grid-header {
  display: contents;
}

.grid-header .grid-item {
  background-color: #f5f5f5;
  font-weight: bold;
  color: #333;
  padding: 16rpx;
  text-align: center;
  font-size: 28rpx;
}

.grid-row {
  display: contents;
}

/* 为表格添加条纹背景 */
.grid-row:nth-child(even) .grid-item {
  background-color: #f9f9f9;
}

.grid-row:nth-child(odd) .grid-item {
  background-color: white;
}

.grid-item {
  padding: 16rpx;
  text-align: center;
  font-size: 28rpx;
}

.grid-item.label {
  background-color: #f5f5f5;
  font-weight: 500;
  color: #333;
  text-align: left;
  padding-left: 20rpx;
}

.grid-row:nth-child(even) .grid-item.label {
  background-color: #f0f0f0;
}

.grid-item.data {
  color: #1a73e8;
  font-weight: 500;
}

.grid-item[data-colspan="2"] {
  grid-column: span 2;
}

/* 我的服务 */
.services-section {
  background-color: white;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 20rpx;
  margin-top: 20rpx;
}

.service-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 8rpx;
  border-radius: 8rpx;
  transition: all 0.3s ease;
}

.service-item:hover {
  background-color: #f5f9ff;
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.08);
}

.service-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.service-name {
  font-size: 24rpx;
  color: #333;
  text-align: center;
}

/* 电商模块 */
.order-section {
  background-color: white;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.order-types {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 0;
}

.order-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx;
  border-radius: 8rpx;
  transition: all 0.3s ease;
}

.order-item:hover {
  background-color: #f5f9ff;
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.08);
}

.order-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
  color: #1a73e8;
}

.order-label {
  font-size: 24rpx;
  color: #333;
}

/* 通用样式 */
h1 {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  color: #333;
}

.view-history-btn {
  display: block;
  width: 100%;
  padding: 20rpx;
  background-color: #1a73e8;
  color: white;
  text-align: center;
  border-radius: 8rpx;
  margin-top: 20rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.view-history-btn:hover {
  background-color: #1557b0;
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 8rpx rgba(26, 115, 232, 0.3);
}