<view class="container">
  <!-- 视力管家卡片 -->
  <view class="health-card">
    <view class="health-card-header">
      <view class="health-card-title">视力管家</view>
      <view class="health-status {{healthStatus === 'healthy' ? 'healthy' : 'warning'}}">
        {{healthStatus === 'healthy' ? '健康' : '需复查'}}
      </view>
    </view>
    <view class="health-card-body">
      <view class="last-check">
        <view class="last-check-label">最近验光</view>
        <view class="last-check-date">{{optometryData.date}}</view>
      </view>
      <view class="check-interval">
        <view class="check-interval-label">距上次验光</view>
        <view class="check-interval-days">{{daysSinceLastCheck}}天</view>
      </view>
    </view>
  </view>
  
  <!-- 验光数据展示区 -->
  <view class="optometry-data">
    <h1>验光数据</h1>
    <view class="data-grid">
      <view class="grid-header">
        <view class="grid-item">参数</view>
        <view class="grid-item">左眼(L)</view>
        <view class="grid-item">右眼(R)</view>
      </view>
      <view class="grid-row">
        <view class="grid-item label">球镜 (SPH)</view>
        <view class="grid-item data">{{optometryData.leftEye.sph}}</view>
        <view class="grid-item data">{{optometryData.rightEye.sph}}</view>
      </view>
      <view class="grid-row">
        <view class="grid-item label">柱镜 (CYL)</view>
        <view class="grid-item data">{{optometryData.leftEye.cyl}}</view>
        <view class="grid-item data">{{optometryData.rightEye.cyl}}</view>
      </view>
      <view class="grid-row">
        <view class="grid-item label">轴位 (AXIS)</view>
        <view class="grid-item data">{{optometryData.leftEye.axis}}</view>
        <view class="grid-item data">{{optometryData.rightEye.axis}}</view>
      </view>
      <view class="grid-row">
        <view class="grid-item label">瞳距 (PD)</view>
        <view class="grid-item data">{{optometryData.pd.left}}</view>
        <view class="grid-item data">{{optometryData.pd.right}}</view>
      </view>
    </view>
    <view class="view-history-btn" bindtap="navigateToOptometryList">查看历史验光记录</view>
  </view>
  
  <!-- 我的服务 -->
  <view class="services-section">
    <h1>我的服务</h1>
    <view class="services-grid">
      <view class="service-item" bindtap="navigateToAppointment">
        <view class="service-icon">📅</view>
        <view class="service-name">预约记录</view>
      </view>
      <view class="service-item">
        <view class="service-icon">🛒</view>
        <view class="service-name">配镜订单</view>
      </view>
      <view class="service-item" bindtap="navigateToOptometry">
        <view class="service-icon">👁️</view>
        <view class="service-name">验光数据</view>
      </view>
      <view class="service-item" bindtap="navigateToMember">
        <view class="service-icon">💎</view>
        <view class="service-name">会员中心</view>
      </view>
      <view class="service-item">
        <view class="service-icon">⚙️</view>
        <view class="service-name">设置</view>
      </view>
    </view>
  </view>
  
  <!-- 电商模块 -->
  <view class="order-section">
    <h1>我的订单</h1>
    <view class="order-types">
      <view class="order-item">
        <view class="order-icon">⏰</view>
        <view class="order-label">待付款</view>
      </view>
      <view class="order-item">
        <view class="order-icon">📦</view>
        <view class="order-label">待发货</view>
      </view>
      <view class="order-item">
        <view class="order-icon">🚚</view>
        <view class="order-label">待收货</view>
      </view>
      <view class="order-item">
        <view class="order-icon">⭐</view>
        <view class="order-label">待评价</view>
      </view>
    </view>
  </view>
</view>