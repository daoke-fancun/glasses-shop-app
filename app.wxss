/* 全局样式 */
page {
  font-family: 'PingFang SC', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  background-color: #f5f5f5;
  color: #333;
}

.container {
  padding: 16rpx;
}

/* 标题样式 */
h1 {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

/* 按钮样式 */
.btn {
  display: block;
  width: 100%;
  padding: 20rpx;
  background-color: #1a73e8;
  color: white;
  text-align: center;
  border-radius: 8rpx;
  margin-top: 20rpx;
}

/* 卡片样式 */
.card {
  background-color: white;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 产品列表样式 */
.product-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.product-item {
  width: 48%;
  margin-bottom: 20rpx;
  background-color: white;
  border-radius: 8rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.product-image {
  width: 100%;
  height: 200rpx;
  background-color: #f0f0f0;
}

.product-info {
  padding: 16rpx;
}

.product-name {
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.product-price {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: bold;
}

/* 表单样式 */
.form-item {
  margin-bottom: 20rpx;
}

.form-label {
  display: block;
  margin-bottom: 8rpx;
  font-size: 28rpx;
}

.form-input {
  width: 100%;
  padding: 16rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
  font-size: 28rpx;
}

/* 预约表单样式 */
.appointment-form {
  background-color: white;
  border-radius: 8rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 个人信息样式 */
.user-info {
  background-color: white;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  margin: 0 auto 20rpx;
}

.user-name {
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.user-phone {
  text-align: center;
  font-size: 24rpx;
  color: #666;
}

/* 验光档案样式 */
.optometry-record {
  background-color: white;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.record-item {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.record-label {
  color: #666;
}

.record-value {
  font-weight: bold;
}